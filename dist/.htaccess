Options +FollowSymLinks -MultiViews
RewriteEngine On

# ── MIME types necesarios para módulos ES (type="module") con Vite ──────────

AddType application/javascript .js .mjs
AddType text/css .css
AddType image/svg+xml .svg
AddType application/json .json

# ── Cabeceras para módulos ES y assets con caché larga ──────────────────────

<IfModule mod_headers.c>
    # Permite que los módulos ES se carguen correctamente
    <FilesMatch "\.(js|mjs)$">
        Header set Content-Type "application/javascript; charset=UTF-8"
    </FilesMatch>

    # Caché larga para assets con hash (Vite genera nombres con hash)
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff2|woff|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Sin caché para index.html (siempre sirve la versión más reciente)
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

</IfModule>

# ── React Router: redirige rutas desconocidas al index.html ─────────────────

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
